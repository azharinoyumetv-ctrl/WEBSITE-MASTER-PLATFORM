# IMPORTANT: URL-encode special characters in the password.
# Common offenders: # → %23  @  → %40  : → %3A  / → %2F
# Example: password YukinoHana#730 must be written as YukinoHana%23730
# Unescaped # truncates the URL at the fragment separator → EAI_AGAIN at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/website_master_platform?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:4000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# JWT
JWT_SECRET="your-jwt-secret-key"
JWT_REFRESH_SECRET="your-refresh-secret-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:4000"
NEXT_PUBLIC_APP_NAME="Website Master Platform"
NEXT_PUBLIC_BASE_DOMAIN="shop.dagangos.com"

# File Storage (AWS S3 or compatible)
STORAGE_BUCKET="your-bucket-name"
STORAGE_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# Payment Gateways (optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AI (optional)
OPENAI_API_KEY="sk-..."

# Email (SendGrid / SES)
SENDGRID_API_KEY="SG...."
EMAIL_FROM="noreply@yourplatform.com"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."
