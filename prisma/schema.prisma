// This is your Prisma schema file
// Website Master Platform — Full Multi-Tenant Schema
// All tables implement tenant_id isolation per PRD spec

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// CORE TENANT INFRASTRUCTURE
// ============================================================

model SystemTenant {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName  String       @map("company_name") @db.VarChar(255)
  subdomain    String       @unique @db.VarChar(63)
  customDomain String?      @unique @map("custom_domain") @db.VarChar(255)
  status       TenantStatus @default(active)
  plan         TenantPlan   @default(core)
  logoUrl      String?      @map("logo_url") @db.Text
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  users                     User[]
  roles                     Role[]
  website                   TenantWebsite?
  pages                     TenantPage[]
  modules                   TenantModule[]
  auditLogs                 AdminAuditLog[]
  userProfiles              TenantUserProfile[]
  invitations               TenantInvitation[]
  policyRules               TenantPolicyRule[]
  categories                TenantCategory[]
  catalogItems              TenantCatalogItem[]
  orders                    TenantOrder[]
  payments                  TenantPayment[]
  idempotencyKeys           PaymentIdempotencyKey[]
  posTerminals              TenantPosTerminal[]
  posSessions               TenantPosSession[]
  inventoryLocations        TenantInventoryLocation[]
  inventoryBalances         TenantInventoryBalance[]
  crmContacts               TenantCrmContact[]
  crmTimeline               TenantCrmTimeline[]
  bookingResources          TenantBookingResource[]
  bookings                  TenantBooking[]
  configSnapshots           TenantConfigSnapshot[]
  aiConfiguration           TenantAiConfiguration?
  aiVectors                 TenantAiKnowledgeVector[]
  notifGateways             TenantNotificationGateway[]
  notifTemplates            TenantNotificationTemplate[]
  analyticsEvents           TenantAnalyticsEvent[]
  analyticsSummaries        TenantAnalyticsDailySummary[]
  apiKeys                   TenantApiKey[]
  apiWebhooks               TenantApiWebhook[]
  authCredentials           TenantAuthCredential[]
  refreshTokens             TenantRefreshToken[]
  storageFiles              TenantStorageRegistry[]
  featureOverrides          TenantFeatureOverride[]
  tenantOrderItems          TenantOrderItem[]
  tenantUserRoles           TenantUserRole[]
  notifLogs                 TenantNotificationLog[]
  incidentLogs              TenantIncidentLog[]
  tenantPaymentLedgers      TenantPaymentLedger[]
  tenantMonitoringRules     TenantMonitoringRule[]
  tenantPosCashDrawerEvents TenantPosCashDrawerEvent[]
  posShifts                 TenantPosShift[]
  paymentDisputes           TenantPaymentDispute[]
  reportSchedules           TenantAnalyticsReportSchedule[]
  generatedReports          TenantGeneratedReport[]
  catalogItemVariants       TenantCatalogItemVariant[]
  catalogItemMedia          TenantCatalogItemMedia[]
  tenantInstances           TenantInstance[]
  tenantDomains             TenantDomain[]
  tenantEntitlements        TenantEntitlement[]

  @@map("system_tenants")
}

enum TenantStatus {
  active
  suspended
  maintenance
}

enum TenantPlan {
  core
  enterprise
  agency
}

// ============================================================
// USERS & AUTHENTICATION
// ============================================================

model User {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String     @map("tenant_id") @db.Uuid
  email             String     @db.VarChar(255)
  passwordHash      String     @map("password_hash") @db.VarChar(255)
  firstName         String?    @map("first_name") @db.VarChar(100)
  lastName          String?    @map("last_name") @db.VarChar(100)
  emailVerified     Boolean    @default(false) @map("email_verified")
  verificationToken String?    @unique @map("verification_token") @db.VarChar(255)
  status            UserStatus @default(pending_verification)
  tokenVersion      Int        @default(1) @map("token_version")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  tenant          SystemTenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       TenantUserRole[]
  profile         TenantUserProfile?
  authCredential  TenantAuthCredential?
  refreshTokens   TenantRefreshToken[]
  uploadedFiles   TenantStorageRegistry[]
  posShifts       TenantPosShift[]
  auditLogs       AdminAuditLog[]
  configSnapshots TenantConfigSnapshot[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("users")
}

enum UserStatus {
  active
  pending_verification
  suspended
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(64)
  description String?  @db.Text
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant          SystemTenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       TenantUserRole[]
  rolePermissions TenantRolePermission[]
  invitations     TenantInvitation[]

  @@unique([tenantId, name])
  @@map("roles")
}

model TenantUserRole {
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId, roleId])
  @@map("tenant_user_roles")
}

model TenantAuthCredential {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  mfaSecretEncrypted   String?   @map("mfa_secret_encrypted") @db.Text
  isMfaEnabled         Boolean   @default(false) @map("is_mfa_enabled")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until") @db.Timestamptz
  passwordResetToken   String?   @unique @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires DateTime? @map("password_reset_expires") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tenant_auth_credentials")
}

model TenantRefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  isRevoked Boolean  @default(false) @map("is_revoked")
  isUsed    Boolean  @default(false) @map("is_used")
  familyId  String?  @map("family_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("tenant_refresh_tokens")
}

// ============================================================
// RBAC
// ============================================================

model TenantPermissionsRegistry {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleKey   String  @map("module_key") @db.VarChar(64)
  actionKey   String  @map("action_key") @db.VarChar(64)
  description String? @db.Text

  rolePermissions TenantRolePermission[]

  @@unique([moduleKey, actionKey])
  @@map("tenant_permissions_registry")
}

model TenantRolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role                      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission TenantPermissionsRegistry @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@map("tenant_role_permissions")
}

model TenantPolicyRule {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  roleKey        String   @map("role_key") @db.VarChar(64)
  moduleTarget   String   @map("module_target") @db.VarChar(64)
  allowedActions String[] @map("allowed_actions") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleKey, moduleTarget])
  @@index([tenantId, roleKey])
  @@map("tenant_policy_rules")
}

// ============================================================
// USER MANAGEMENT
// ============================================================

model TenantUserProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  phoneNumber String?  @map("phone_number") @db.VarChar(32)
  avatarUrl   String?  @map("avatar_url") @db.Text
  preferences Json     @default("{\"locale\":\"en\",\"timezone\":\"UTC\"}")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_user_profiles")
}

model TenantInvitation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String    @db.VarChar(255)
  invitedBy      String    @map("invited_by") @db.Uuid
  tokenHash      String    @unique @map("token_hash") @db.VarChar(255)
  assignedRoleId String    @map("assigned_role_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role         @relation(fields: [assignedRoleId], references: [id])

  @@index([tokenHash])
  @@map("tenant_invitations")
}

// ============================================================
// WEBSITE MODULE
// ============================================================

model TenantWebsite {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                      String   @unique @map("tenant_id") @db.Uuid
  siteTitle                     String   @map("site_title") @db.VarChar(255)
  faviconUrl                    String?  @map("favicon_url") @db.Text
  themeConfig                   Json     @default("{}") @map("theme_config")
  globalSeoMetadata             Json     @default("{\"keywords\":[],\"description\":\"\"}") @map("global_seo_metadata")
  isActive                      Boolean  @default(true) @map("is_active")
  xenditEncryptedSecret         String?  @map("xendit_encrypted_secret") @db.Text
  xenditEncryptedSecretIv       String?  @map("xendit_encrypted_secret_iv") @db.VarChar(64)
  xenditEncryptedWebhookToken   String?  @map("xendit_encrypted_webhook_token") @db.Text
  xenditEncryptedWebhookTokenIv String?  @map("xendit_encrypted_webhook_token_iv") @db.VarChar(64)
  xenditEnabled                 Boolean  @default(false) @map("xendit_enabled")
  midtransEncryptedServerKey    String?  @map("midtrans_encrypted_server_key") @db.Text
  midtransEncryptedServerKeyIv  String?  @map("midtrans_encrypted_server_key_iv") @db.VarChar(64)
  midtransEnabled               Boolean  @default(false) @map("midtrans_enabled")
  dokuEnabled                 Boolean   @default(false) @map("doku_enabled")
  dokuEnvironment             String?   @default("sandbox") @map("doku_environment")
  dokuClientId                String?   @map("doku_client_id") @db.Text
  dokuMerchantPublicKey       String?   @map("doku_merchant_public_key") @db.Text
  dokuSnapTokenUrl            String?   @map("doku_snap_token_url") @db.Text
  dokuSharedKey               String?   @map("doku_shared_key") @db.Text
  dokuPreferredChannel        String?   @default("all") @map("doku_preferred_channel")
  createdAt                     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_websites")
}

model TenantPage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  slug         String   @db.VarChar(255)
  title        String   @db.VarChar(255)
  layoutBlocks Json     @default("[]") @map("layout_blocks")
  seoMetadata  Json     @default("{}") @map("seo_metadata")
  isPublished  Boolean  @default(false) @map("is_published")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  redirectTo   String?  @map("redirect_to") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, slug])
  @@map("tenant_pages")
}

// ============================================================
// ADMIN MODULE
// ============================================================

model TenantModule {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  moduleKey            String    @map("module_key") @db.VarChar(64)
  isEnabled            Boolean   @default(false) @map("is_enabled")
  configuredProperties Json      @default("{}") @map("configured_properties")
  activatedAt          DateTime? @map("activated_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@map("tenant_modules")
}

model AdminAuditLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  actionPerformed String   @map("action_performed") @db.VarChar(128)
  targetResource  String   @map("target_resource") @db.VarChar(128)
  ipAddress       String   @map("ip_address") @db.VarChar(45)
  payloadChanges  Json     @default("{}") @map("payload_changes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id])

  @@index([tenantId, actionPerformed])
  @@map("admin_audit_logs")
}

// ============================================================
// CATALOG MODULE
// ============================================================

model TenantCategory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  parentId        String?  @map("parent_id") @db.Uuid
  name            String   @db.VarChar(255)
  slug            String   @db.VarChar(255)
  attributeSchema Json     @default("[]") @map("attribute_schema")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   SystemTenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   TenantCategory?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children TenantCategory[]    @relation("CategoryHierarchy")
  items    TenantCatalogItem[]

  @@unique([tenantId, slug])
  @@map("tenant_categories")
}

model TenantCatalogItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  categoryId       String?  @map("category_id") @db.Uuid
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  basePrice        Decimal  @default(0.00) @map("base_price") @db.Decimal(12, 2)
  sku              String?  @db.VarChar(100)
  customAttributes Json     @default("{}") @map("custom_attributes")
  isVisible        Boolean  @default(true) @map("is_visible")
  imageUrls        String[] @map("image_urls")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant            SystemTenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category          TenantCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems        TenantOrderItem[]
  inventoryBalances TenantInventoryBalance[]
  variants          TenantCatalogItemVariant[]
  media             TenantCatalogItemMedia[]

  @@index([tenantId, categoryId])
  @@map("tenant_catalog_items")
}

// ============================================================
// E-COMMERCE MODULE
// ============================================================

model TenantOrder {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  userId          String?     @map("user_id") @db.Uuid
  guestEmail      String?     @map("guest_email") @db.VarChar(255)
  orderStatus     OrderStatus @default(pending) @map("order_status")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency        String      @default("USD") @db.VarChar(3)
  shippingAddress Json        @default("{}") @map("shipping_address")
  promoCode       String?     @map("promo_code") @db.VarChar(50)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  notes           String?     @db.Text
  receiptUrl      String?     @map("receipt_url") @db.Text
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  tenant               SystemTenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items                TenantOrderItem[]
  payments             TenantPayment[]
  tenantPaymentLedgers TenantPaymentLedger[]

  @@index([tenantId, orderStatus])
  @@map("tenant_orders")
}

enum OrderStatus {
  pending
  paid
  pending_fulfillment
  processing
  shipped
  completed
  cancelled
}

model TenantOrderItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  catalogItemId String   @map("catalog_item_id") @db.Uuid
  quantity      Int
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant      SystemTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       TenantOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalogItem TenantCatalogItem @relation(fields: [catalogItemId], references: [id])

  @@map("tenant_order_items")
}

// ============================================================
// PAYMENT MODULE
// ============================================================

model TenantPayment {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String        @map("tenant_id") @db.Uuid
  orderId               String        @map("order_id") @db.Uuid
  processorKey          String        @map("processor_key") @db.VarChar(64)
  externalTransactionId String?       @unique @map("external_transaction_id") @db.VarChar(255)
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("USD") @db.VarChar(3)
  paymentStatus         PaymentStatus @default(initiated) @map("payment_status")
  metadata              Json          @default("{}")
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  tenant               SystemTenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order                TenantOrder           @relation(fields: [orderId], references: [id])
  tenantPaymentLedgers TenantPaymentLedger[]
  disputes             TenantPaymentDispute[]

  @@index([tenantId, paymentStatus])
  @@map("tenant_payments")
}

enum PaymentStatus {
  initiated
  succeeded
  failed
  refunded
  expired
  disputed
}

model PaymentIdempotencyKey {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  idempotencyKey  String   @unique @map("idempotency_key") @db.VarChar(255)
  responsePayload Json     @map("response_payload")
  expiresAt       DateTime @map("expires_at") @db.Timestamptz

  tenant SystemTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payment_idempotency_keys")
}

// ============================================================
// POS MODULE
// ============================================================

model TenantPosTerminal {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String         @map("tenant_id") @db.Uuid
  terminalName       String         @map("terminal_name") @db.VarChar(100)
  hardwareIdentifier String         @unique @map("hardware_identifier") @db.VarChar(255)
  status             TerminalStatus @default(offline)
  locationId         String?        @map("location_id") @db.Uuid
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant   SystemTenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions TenantPosSession[]
  shifts   TenantPosShift[]

  @@index([tenantId, status])
  @@map("tenant_pos_terminals")
}

enum TerminalStatus {
  online
  offline
  maintenance
}

model TenantPosSession {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  terminalId     String        @map("terminal_id") @db.Uuid
  openedBy       String        @map("opened_by") @db.Uuid
  closedBy       String?       @map("closed_by") @db.Uuid
  openingBalance Decimal       @default(0.00) @map("opening_balance") @db.Decimal(12, 2)
  closingBalance Decimal?      @map("closing_balance") @db.Decimal(12, 2)
  status         SessionStatus @default(open)
  openedAt       DateTime      @default(now()) @map("opened_at") @db.Timestamptz
  closedAt       DateTime?     @map("closed_at") @db.Timestamptz

  tenant           SystemTenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminal         TenantPosTerminal          @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  cashDrawerEvents TenantPosCashDrawerEvent[]

  @@map("tenant_pos_sessions")
}

enum SessionStatus {
  open
  reconciled
}

model TenantPosCashDrawerEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(32)
  amount      Decimal? @db.Decimal(12, 2)
  notes       String?  @db.Text
  performedBy String?  @map("performed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  SystemTenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session TenantPosSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sessionId])
  @@index([tenantId, createdAt])
  @@map("tenant_pos_cash_drawer_events")
